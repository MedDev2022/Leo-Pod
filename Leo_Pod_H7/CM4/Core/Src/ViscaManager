void DayCam::sendVISCACommand(uint8_t command1, uint8_t command2, uint8_t command3) {
    // Send VISCA command

	uint8_t command[] = { 0x81, VISCA_ADDRESS, command1, command2, command3 };
    viscaSerial->write((char*)command, sizeof(command));
    Utils::DebugHexMsg((char*)command, sizeof(command));
}

void DayCam::moveCameraUp() {
	uint8_t command[] = { 0x81, 0x01, 0x06, 0x01, 0x03, 0x03, 0x03, 0x03, 0xFF };
    sendVISCACommand(command, sizeof(command));
}

void DayCam::sendVISCACommand(uint8_t address, uint8_t command1, uint8_t command2, uint8_t data1, uint8_t data2)
{
	uint8_t checksum = address ^ command1 ^ command2 ^ data1 ^ data2;

    viscaSerial->write(0x81); // Header
    viscaSerial->write(address); // Address
    viscaSerial->write(command1); // Command 1
    viscaSerial->write(command2); // Command 2
    viscaSerial->write(data1); // Data 1
    viscaSerial->write(data2); // Data 2
    viscaSerial->write(checksum); // Checksum

}

// Function to send a VISCA command to the camera
void DayCam::sendVISCACommand(uint8_t cmd[], int length) {

    for (int i = 0; i < length; i++) {
        viscaSerial->write(cmd[i]); // Send each byte of the command
    }

}

