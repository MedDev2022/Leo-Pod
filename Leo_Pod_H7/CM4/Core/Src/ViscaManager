}

void DayCam::checkPositions(char* msg, size_t size) {

    serial.println("=> checkPositions");
    int pos;
    if (msg[0] == 0x90 && msg[1] == 0x50) {

        serial.println("=> Position");
        switch (itemPos)
        {
        case eItemPos::ZOOM:
            pos = pqrsHexBytesPosToIntPos(msg);
            zoomPos = pos / 16;
            if (zoomPos == 1024)
                zoomPos = 1023;
            serial.print("===> Zoom Pos = ");
            serial.println(std::to_string(zoomPos).c_str());
            break;
        case eItemPos::FOCUS:
            pos = pqrsHexBytesPosToIntPos(msg);
            focusPos = pos;
            /*focusPos = outputLevels * (pos - minValueFocus) / focusLevels;
            if (focusPos == 1024)
                focusPos = 1023;*/
            serial.print("===> focusPos = ");
            serial.print(pos);
            serial.print("   **************************");

            break;
        default:
            break;
        }
        itemPos = eItemPos::NONE;
        if (zoomPos != 0xFFFF && focusPos != 0xFFFF) {
            serial.print("============> Zoom Pos = ");
            serial.print(zoomPos);
            serial.print("============> Focus Pos = ");
            serial.println(std::to_string(focusPos).c_str());
            //ViscaManager::transferPositionSPI(zoomPos);
        }
    }
}

