void DayCam::setup() {

    // Set VISCA protocol configuration (optional)
    sendVISCACommand(0x30, 0x01, 0x00); // Set command to VISCA protocol version 1.0

    //Send Address command
    setAddress();

    //delay(delayTime);
    HAL_Delay(500);  //delay to allow camera time for next command


    //wait for DayCam ready
    uint8_t tempBuff[4];
    int i=0;
    int timeOUT = HAL_GetTick();
    do{
		timeOUT = HAL_GetTick();
		sendVISCACommand(power_Inq, sizeof(power_Inq));
		if (viscaSerial->available()){
			viscaSerial->readBytes(tempBuff, 4);
		}
			for (; i<3; i++){
				if (tempBuff[i] != res_Power_ON[i])
					i=5;
			}
			HAL_Delay(500);
    }while((HAL_GetTick() - timeOUT) < 200 && i==4);

    serial.println("DayCAM ready");

//    delay(2000);
   
    // Set auto focus
  //  sendVISCACommand(focus_auto, sizeof(focus_auto));
     // Set manual focus
    sendVISCACommand(focus_manual, sizeof(focus_manual));

    zoomPosInq();
    HAL_Delay(500);
    focusPosInq();
}


