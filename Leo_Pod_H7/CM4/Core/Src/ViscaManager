// Total = 0x4000 = 16384  
// 16384 : 16 = 1024
int DayCam::pqrsHexBytesPosToIntPos(char* msg) {
    //cout << "bytesToHex" << endl;
    // byte CAM_ZoomPosInqRes[7] = { 0x90, 0x50, 0x00, 0x00, 0x00, 0x00, 0xFF };
    //byte CAM_ZoomPosInqRes[7] = { 0x90, 0x50, 0x04, 0x00, 0x00, 0x00, 0xFF };
    long total = 0;
    //cout << "total=" << total << endl;
    int i = 2;
    total = msg[i++] & 0x0F;
    for (; i < 6; i++) {
        //cout << "total=" << total << endl;
        total = (total << 4) | msg[i] & 0x0F;
    }
    serial.print("=> total = ");
    serial.println(std::to_string(total).c_str());
    // cout << "total=" << total << endl;
    return total;
}


