void DayCam::loop() {

	unsigned long myTime = HAL_GetTick();


		// read from port 1, send to port 0:
		if (viscaSerial->available()) {
		   //Serial.println("RX:");
			int len = viscaSerial->available();
			uint8_t byte;
			int rxLength = 0;
			int inByte;
			long timeout = HAL_GetTick();
			do {
				inByte = viscaSerial->readBytes(&byte, sizeof(uint8_t));
				rxBytes[rxLength++] = byte;
			} while (byte != 0xFF && viscaSerial->available());//( millis() - timeout) > 250 && viscaSerial->available() ); //MK bad condition to exit, consider to add timeout

			if (byte == 0xFF){
			Utils::DebugMsg("RX Answer: ", false);
			Utils::DebugHexMsg((char*)&rxBytes, sizeof(uint8_t) * rxLength);
			checkPositions((char*)&rxBytes, sizeof(uint8_t) * rxLength);
