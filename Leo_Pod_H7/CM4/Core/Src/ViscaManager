// Function to send VISCA command to set zoom position
void DayCam::setZoomPosition(uint8_t zoomHighByte, uint8_t zoomLowByte) {
    uint8_t command[] = { 0x81, 0x01, 0x04, 0x47, 0x7E, zoomHighByte, zoomLowByte }; // VISCA command to set zoom position

    // Calculate checksum
    uint8_t checksum = 0;
    for (int i = 0; i < 6; i++) {
        checksum -= command[i];
    }
    command[6] = checksum;
}


